model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Transform File from wisesheets_results'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform File from wisesheets_results\Helper Queries'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform File from wisesheets_valinput'

	annotation PBI_QueryGroupOrder = 2

queryGroup 'Transform File from wisesheets_valinput\Helper Queries'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform File from wisesheets_results (2)'

	annotation PBI_QueryGroupOrder = 4

queryGroup 'Transform File from wisesheets_results (2)\Helper Queries'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform File from wisesheets_forecasted'

	annotation PBI_QueryGroupOrder = 6

queryGroup 'Transform File from wisesheets_forecasted\Helper Queries'

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Results","Sample File","Parameter1","Transform Sample File","Transform File","ValInput","Sample File (2)","Parameter2","Transform Sample File (2)","Transform File (2)","FCF_History","Dividends_History","Comps","_Measures","Sample File (3)","Parameter3","Transform Sample File (3)","Transform File (3)","DCF_Projection","Sample File (4)","Parameter4","Transform Sample File (4)","Transform File (4)"]

annotation PBI_ProTooling = ["DevMode"]

ref table Results
ref table ValInput
ref table FCF_History
ref table Dividends_History
ref table Comps
ref table _Measures
ref table ModelLabels
ref table AssumptionLabels
ref table DCFAssumptionLabels
ref table DCF_Projection
ref table DCFProjectionRows

ref cultureInfo en-US

